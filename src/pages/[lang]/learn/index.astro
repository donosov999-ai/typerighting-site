---
import Base from '../../../layouts/Base.astro';
import LearnIndex from '../../../components/LearnIndex.astro';
import type { Lang } from '../../../i18n/ui';

export function getStaticPaths() {
  return (['ru', 'es', 'de', 'fr', 'it', 'pt'] as Lang[]).map((lang) => ({ params: { lang } }));
}
const { lang } = Astro.params as { lang: Lang };
---
<Base lang={lang}>
  <LearnIndex lang={lang} />
</Base>
